algoritmo "L03I"
// Funçăo : Ler 10 valores e mostrar soma e média aritmética
// Autor : Mhell Barroca Novaes
// Data : 24/08/2025
// Seçăo de Declaraçőes
//Elaborar um programa que efetue a leitura de 10 valores numéricos e apresente no final o total do somatório e a média aritmética dos valores lidos
var
cont: inteiro
x, soma, media: real
inicio
// Seçăo de Comandos
cont := 1
soma := 0
enquanto (cont <= 10) faca
   escreva("Digite o ", cont, "ş valor: ")
   leia(x)
   soma := soma + x
   cont := cont + 1
fimenquanto
media := soma / 10
escreval("Somatório = ", soma:0:2)
escreval("Média = ", media:0:2)
fimalgoritmo
