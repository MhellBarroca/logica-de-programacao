algoritmo "Calculadora"
// Funįão :
// Autor : Mhell Barroca Novaes
// Data : 19/08/2025
// Calculadora 1.0
// Seįão de Declaraįões
//1-SOMA
//2-SUBTRAĮÃO
//3-MULTIPLICAĮÃO
//4-DIVISÃO
//5-EXPONENCIAĮÃO

var
n1,n2,res : REAL
oper:caracter
inicio
// Seįão de Comandos
enquanto (oper<>"6")faca

   Escreval("Calculadora 1.0")
   Escreval("1 - Soma")
   Escreval("2 - SUBTRAĮÃO")
   Escreval("3 - MULTIPLICAĮÃO")
   Escreval("4 - DIVISÃO")
   Escreval("5 - EXPONENCIAĮÃO")
   Escreval("6 - Sair")

   Escreva("Escolha a Operaįão[1/2/3/4/5 ] ou 6 para sair ")
   Leia(oper)

   se (oper<>"1") e (oper<>"2") e (oper<>"3") e (oper<>"4") e (oper<>"5") e (oper<>"6") entao
      Escreval("Operaįão inválida ")
      Escreva("Digite uma opįão válida[1/2/3/4/5] ou 6 para saida:  ")
      Leia(oper)
   fimse

   se (oper="6")entao
      Escreva ("Opįão Sair escolhida! ")
   fimalgoritmo
fimse

Escreva("Digite valor 1: ")
Leia(n1)
Escreva("Digite valor 2: ")
Leia(n2)

escolha oper
caso "1"
   limpatela
   res:=n1+n2
   Escreval (n1, " - ", n2 ," = ",res)

caso "2"
   limpatela
   res:=n1 - n2
   Escreval (n1, " - ", n2 ," = ",res)
caso "3"
   limpatela
   res:=n1 * n2
   Escreval (n1, " x ", n2 ," = ",res)

caso "4"
   limpatela
   res:=n1 / n2
   Escreval (n1, " / ", n2 ," = ",res)

caso "5"
   limpatela
   res:=n1 ^ n2
   Escreval (n1, " ^ ", n2 ," = ",res)
outrocaso
fimescolha
fimenquanto
fimalgoritmo

