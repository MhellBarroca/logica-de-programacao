algoritmo "semnome"
// Funįão :Condiįoes
// Autor : Mhell Barroca
// Data : 19/08/2025
// Seįão de Declaraįões
var
idade:inteiro
inicio
// Seįão de Comandos
Escreva("Digite a sua idade: ")
Leia(idade)

se (idade >= 18) entao
   Escreva("Vocę é maior de idade, tendo :", idade , " anos.")
senao
   Escreva("Vocę é menor de idade, tendo :", idade , " anos.")
fimse

fimalgoritmo
